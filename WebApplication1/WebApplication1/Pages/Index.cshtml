@page
@model IndexModel
@{
    ViewData["Title"] = "หน้าหลัก";
}

<div class="container-xl">
    <!-- Hero -->
    <div class="hero-section">
        <div class="position-relative" style="z-index:1">
            <div class="hero-title"><i class="bi bi-bank2 me-2"></i>ระบบจองซื้อทรัพย์</div>
            <div class="hero-subtitle">ค้นหาและจองซื้อทรัพย์ได้สะดวก รวดเร็ว ปลอดภัย</div>
            <div class="d-flex gap-3 flex-wrap">
                <a asp-page="/Assets/Index" class="btn btn-light fw-bold px-4 py-2">
                    <i class="bi bi-collection me-2"></i>เลือกดูทรัพย์ทั้งหมด
                </a>
                <a asp-page="/MyBookings/Index" class="btn btn-outline-light fw-semibold px-4 py-2">
                    <i class="bi bi-bookmark-check me-2"></i>ทรัพย์ที่ลงทะเบียน
                </a>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon stat-icon-blue"><i class="bi bi-collection"></i></div>
                <div>
                    <div class="stat-value">@Model.TotalAssets.ToString("N0")</div>
                    <div class="stat-label">ทรัพย์ทั้งหมด</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon stat-icon-green"><i class="bi bi-check-circle"></i></div>
                <div>
                    <div class="stat-value">@Model.AvailableAssets.ToString("N0")</div>
                    <div class="stat-label">ว่าง / พร้อมจอง</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon stat-icon-orange"><i class="bi bi-bookmark"></i></div>
                <div>
                    <div class="stat-value">@Model.ReservedAssets.ToString("N0")</div>
                    <div class="stat-label">ถูกจองแล้ว</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon stat-icon-gray"><i class="bi bi-bag-check"></i></div>
                <div>
                    <div class="stat-value">@Model.TotalBookings.ToString("N0")</div>
                    <div class="stat-label">การจองทั้งหมด</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Menu Cards -->
    <div class="row g-4">
        <div class="col-md-6">
            <a asp-page="/Assets/Index" class="menu-card">
                <div class="menu-card-icon menu-card-icon-blue">
                    <i class="bi bi-collection"></i>
                </div>
                <div class="menu-card-title">เลือกซื้อทรัพย์</div>
                <div class="menu-card-desc">
                    ค้นหา กรอง และเลือกซื้อทรัพย์ที่ต้องการ<br>
                    มีทรัพย์ให้เลือกกว่า <strong>@Model.TotalAssets</strong> รายการ
                </div>
            </a>
        </div>
        <div class="col-md-6">
            <a asp-page="/MyBookings/Index" class="menu-card">
                <div class="menu-card-icon menu-card-icon-purple">
                    <i class="bi bi-bookmark-check"></i>
                </div>
                <div class="menu-card-title">ทรัพย์ที่ลงทะเบียน</div>
                <div class="menu-card-desc">
                    ดูรายการทรัพย์ที่ลงทะเบียนจองไว้<br>
                    ตรวจสอบสถานะและจัดการการจอง
                </div>
            </a>
        </div>
    </div>
</div>
