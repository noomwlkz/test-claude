@page
@model WebApplication1.Pages.Login.IndexModel
@{
    Layout = null;
    ViewData["Title"] = "เข้าสู่ระบบ";
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>เข้าสู่ระบบ - ระบบจองซื้อทรัพย์</title>
    <link rel="stylesheet" href="~/lib/sarabun/sarabun.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Sarabun', sans-serif;
            min-height: 100vh;
            display: flex;
            background: #f0f4f8;
        }

        /* ── Left panel ── */
        .login-left {
            width: 55%;
            background: linear-gradient(145deg, #0a2342 0%, #1a4a8a 50%, #1565c0 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px 48px;
            position: relative;
            overflow: hidden;
        }
        .login-left::before {
            content: '';
            position: absolute;
            width: 500px; height: 500px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            top: -150px; right: -150px;
        }
        .login-left::after {
            content: '';
            position: absolute;
            width: 350px; height: 350px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            bottom: -100px; left: -80px;
        }
        .brand-logo {
            width: 88px; height: 88px;
            background: rgba(255,255,255,0.12);
            border-radius: 24px;
            display: flex; align-items: center; justify-content: center;
            font-size: 42px; color: #fff;
            margin-bottom: 28px;
            border: 1.5px solid rgba(255,255,255,0.18);
            backdrop-filter: blur(4px);
        }
        .brand-name {
            font-size: 26px; font-weight: 700;
            color: #fff; letter-spacing: 0.3px;
            margin-bottom: 10px; text-align: center;
        }
        .brand-sub {
            font-size: 15px; color: rgba(255,255,255,0.65);
            text-align: center; line-height: 1.6; max-width: 320px;
        }
        .feature-list {
            margin-top: 48px; list-style: none;
            display: flex; flex-direction: column; gap: 16px;
            width: 100%; max-width: 340px;
        }
        .feature-list li {
            display: flex; align-items: center; gap: 14px;
            color: rgba(255,255,255,0.82); font-size: 14px;
        }
        .feature-icon {
            width: 38px; height: 38px; border-radius: 10px;
            background: rgba(255,255,255,0.1);
            display: flex; align-items: center; justify-content: center;
            font-size: 17px; color: #64b5f6; flex-shrink: 0;
        }

        /* ── Right panel ── */
        .login-right {
            width: 45%;
            display: flex; flex-direction: column;
            justify-content: center; align-items: center;
            padding: 60px 48px;
            background: #fff;
        }
        .login-card { width: 100%; max-width: 400px; }
        .login-title {
            font-size: 26px; font-weight: 700;
            color: #0a2342; margin-bottom: 6px;
        }
        .login-desc { font-size: 14px; color: #6b7280; margin-bottom: 36px; }

        .form-label-custom {
            font-size: 13px; font-weight: 600;
            color: #374151; margin-bottom: 6px; display: block;
        }
        .input-wrap {
            position: relative; margin-bottom: 18px;
        }
        .input-icon {
            position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
            color: #9ca3af; font-size: 17px; pointer-events: none;
        }
        .form-control-custom {
            width: 100%; height: 50px;
            border: 1.5px solid #e5e7eb; border-radius: 12px;
            padding: 0 16px 0 44px; font-size: 15px; font-family: 'Sarabun', sans-serif;
            color: #111827; background: #f9fafb;
            transition: border-color .2s, box-shadow .2s;
            outline: none;
        }
        .form-control-custom:focus {
            border-color: #1565c0;
            box-shadow: 0 0 0 3px rgba(21,101,192,0.12);
            background: #fff;
        }
        .form-control-custom.is-error { border-color: #ef4444; }

        .btn-login {
            width: 100%; height: 52px; border-radius: 12px;
            background: linear-gradient(135deg, #1565c0, #1a4a8a);
            border: none; color: #fff; font-size: 16px; font-weight: 600;
            font-family: 'Sarabun', sans-serif; cursor: pointer;
            transition: transform .15s, box-shadow .15s;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            margin-top: 8px;
        }
        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(21,101,192,0.35);
        }
        .btn-login:active { transform: translateY(0); }

        .error-box {
            background: #fef2f2; border: 1px solid #fecaca;
            border-radius: 10px; padding: 12px 16px;
            color: #dc2626; font-size: 13.5px;
            display: flex; align-items: flex-start; gap: 10px;
            margin-bottom: 20px;
        }
        .divider {
            display: flex; align-items: center; gap: 12px;
            color: #d1d5db; font-size: 12px; margin: 24px 0;
        }
        .divider::before, .divider::after {
            content: ''; flex: 1; height: 1px; background: #e5e7eb;
        }
        .help-text {
            font-size: 12.5px; color: #9ca3af; text-align: center; margin-top: 28px;
        }
        .footer-note {
            font-size: 12px; color: #9ca3af;
            text-align: center; margin-top: 40px;
        }

        @@media (max-width: 768px) {
            body { flex-direction: column; }
            .login-left { width: 100%; padding: 40px 24px; min-height: 220px; }
            .feature-list { display: none; }
            .login-right { width: 100%; padding: 40px 24px; }
        }
    </style>
</head>
<body>

    <!-- ── Left branding panel ── -->
    <div class="login-left">
        <div class="brand-logo"><i class="bi bi-buildings"></i></div>
        <div class="brand-name">ระบบจองซื้อทรัพย์</div>
        <div class="brand-sub">ค้นหาและลงทะเบียนซื้อทรัพย์ได้อย่างสะดวกรวดเร็ว ปลอดภัย และโปร่งใส</div>

        <ul class="feature-list">
            <li>
                <div class="feature-icon"><i class="bi bi-collection"></i></div>
                <span>เรียกดูทรัพย์ทั้งหมดกว่า 2,000 รายการ</span>
            </li>
            <li>
                <div class="feature-icon"><i class="bi bi-clipboard2-check"></i></div>
                <span>ลงทะเบียนแสดงความจำนงซื้อได้ทันที</span>
            </li>
            <li>
                <div class="feature-icon"><i class="bi bi-shield-check"></i></div>
                <span>ข้อมูลปลอดภัย ยืนยันตัวตนด้วยบัตรประชาชน</span>
            </li>
            <li>
                <div class="feature-icon"><i class="bi bi-bell"></i></div>
                <span>ติดตามสถานะทรัพย์ที่ลงทะเบียนไว้</span>
            </li>
        </ul>
    </div>

    <!-- ── Right form panel ── -->
    <div class="login-right">
        <div class="login-card">

            <div class="login-title">เข้าสู่ระบบ</div>
            <div class="login-desc">กรอกข้อมูลที่ลงทะเบียนไว้เพื่อเข้าใช้งาน</div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error-box">
                    <i class="bi bi-exclamation-circle-fill flex-shrink-0 mt-1"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <label class="form-label-custom">เบอร์โทรศัพท์</label>
                <div class="input-wrap">
                    <i class="bi bi-phone input-icon"></i>
                    <input type="tel" name="Phone" value="@Model.Phone"
                           class="form-control-custom @(!string.IsNullOrEmpty(Model.ErrorMessage) ? "is-error" : "")"
                           placeholder="0xx-xxx-xxxx" autocomplete="tel" />
                </div>

                <label class="form-label-custom">เลขบัตรประชาชน</label>
                <div class="input-wrap">
                    <i class="bi bi-credit-card-2-front input-icon"></i>
                    <input type="text" name="IdCard" value="@Model.IdCard"
                           class="form-control-custom @(!string.IsNullOrEmpty(Model.ErrorMessage) ? "is-error" : "")"
                           placeholder="x-xxxx-xxxxx-xx-x" maxlength="17" autocomplete="off" />
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right"></i> เข้าสู่ระบบ
                </button>
            </form>

            <div class="divider">หรือ</div>

            <a href="/Assets" style="display:flex;align-items:center;justify-content:center;gap:8px;
               height:48px;border-radius:12px;border:1.5px solid #e5e7eb;color:#374151;
               font-size:14px;font-weight:600;text-decoration:none;transition:border-color .2s;"
               onmouseover="this.style.borderColor='#1565c0';this.style.color='#1565c0'"
               onmouseout="this.style.borderColor='#e5e7eb';this.style.color='#374151'">
                <i class="bi bi-collection"></i> ดูรายการทรัพย์
            </a>

            <div class="help-text">
                หากไม่สามารถเข้าสู่ระบบได้ กรุณาติดต่อเจ้าหน้าที่
            </div>

            <div class="footer-note">
                &copy; @DateTime.Now.Year ระบบจองซื้อทรัพย์ · ข้อมูลถูกเข้ารหัสและปลอดภัย
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
